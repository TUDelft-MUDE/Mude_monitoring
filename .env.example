# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values:
#   cp .env.example .env && nano .env
# .env is git-ignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────

# SMTP email alerts (replaces AWS SNS).
# Leave SMTP_HOST empty to disable email alerts (checker still runs).
#   University relay : smtp.tudelft.nl / 25    (no auth, on-campus only)
#   Gmail            : smtp.gmail.com  / 587   (needs a 16-char app password)
# Note: on edu01 only port 25 is reachable (587/465 are firewalled).
SMTP_HOST=smtp.tudelft.nl
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Alert sender.
ALERT_EMAIL_FROM=mude-monitor@tudelft.nl

# Alert recipients are managed in backend/recipients.txt (one email per line) so
# a non-technical maintainer can edit them from GitHub. ALERT_EMAIL_TO below is
# only a fallback used when that file is missing/empty (comma-separated).
ALERT_EMAIL_TO=you@tudelft.nl

# Public base URL of the dashboard (used in alert links).
# Dedicated vhost — NOT the edu01 root, which already hosts another site.
PUBLIC_URL=https://mude-monitoring.citg.tudelft.nl

# API key — required to add/delete targets. Generate one with:
#   openssl rand -hex 32
API_KEY=change-me-to-a-long-random-string

# CORS — comma-separated list of allowed frontend origins.
# Must match how users reach the dashboard in the browser.
ALLOWED_ORIGINS=https://mude-monitoring.citg.tudelft.nl

# Microsoft Teams webhook (optional — leave empty to disable Teams alerts).
TEAMS_WEBHOOK_URL=
